{
  "name": "autonomy-calibration",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate": "node src/cli/generate.mjs",
    "probe:claude": "node scripts/probe_claude_code.mjs",
    "probe:codex": "node scripts/probe_codex.mjs",
    "probe:litellm": "AWS_PROFILE=${AWS_PROFILE:-production-developer} /usr/bin/python3 test_litellm.py",
    "download-samples": "python3 scripts/download_samples.py --limit 5",
    "setup-vendor": "python3 scripts/setup_vendor.py",
    "passk": "node scripts/run_passk.mjs",
    "evaluate": "python3 scripts/evaluate_official.py",
    "summarize": "python3 scripts/summarize_passk.py",
    "smoke:pass3:generate": "node src/cli/generate.mjs --harness all --k 3 --limit 1 --run-id ${RUN_ID:-both-pass3-smoke} --attempt-timeout-ms ${HARNESS_ATTEMPT_TIMEOUT_MS:-900000}",
    "smoke:pass3:evaluate": "python3 scripts/evaluate_official.py --run-id ${RUN_ID:-both-pass3-smoke}",
    "smoke:pass3:summarize": "python3 scripts/summarize_passk.py --run-id ${RUN_ID:-both-pass3-smoke} --k 3",
    "test": "node --test tests/*.test.mjs && python3 -m unittest discover -s tests -p '*_test.py'"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.123",
    "@openai/codex": "^0.128.0",
    "@openai/codex-sdk": "^0.128.0"
  }
}
